<!doctype html>
<html>
  <head>
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <title>Reset Your Password - TrialEx App</title>
    <style>
      body {
        background-color: #f6f6f6;
        font-family: sans-serif;
        font-size: 14px;
        margin: 0;
        padding: 0;
      }
      .container {
        max-width: 480px;
        margin: 0 auto;
        background: #fff;
        border-radius: 8px;
        padding: 32px 24px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
      }
      .logo {
        display: block;
        margin: 0 auto 24px auto;
        width: 120px;
      }
      h2 {
        text-align: center;
        color: #1a237e;
        margin-bottom: 16px;
      }
      .otp-box {
        font-size: 24px;
        letter-spacing: 8px;
        text-align: center;
        margin: 24px 0;
        font-weight: bold;
        color: #1976d2;
      }
      .btn {
        display: block;
        width: 100%;
        background: #1976d2;
        color: #fff;
        border: none;
        border-radius: 4px;
        padding: 12px 0;
        font-size: 16px;
        text-align: center;
        text-decoration: none;
        margin-top: 24px;
        font-weight: bold;
      }
      .info {
        color: #333;
        margin-bottom: 16px;
        text-align: center;
      }
      .footer {
        text-align: center;
        color: #999;
        font-size: 12px;
        margin-top: 32px;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h2>Reset Your Password</h2>
      <div class="info">
        Hello {{email}},<br>
        You requested to reset your password for your Trialex account.<br>
        Please use the OTP code below to continue in the app.
      </div>
      <div class="otp-box">{{otp}}</div>
      <div class="info">
        Hello {{email}},<br>
        You requested to reset your password for your Trialex account.<br>
        Please use the OTP code below to continue in the app.<br>
        <b>Note: This OTP is valid for 10 minutes only.</b>
      </div>
      <div class="footer">
        &copy; {{year}} Trialex App. All rights reserved.
      </div>
    </div>
  </body>
</html>
